# Server
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed origins (e.g. http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# Database
# DATABASE_URL: main connection string (can be Supabase pooler/pgbouncer)
# DIRECT_URL: direct connection string (recommended for migrations when using pooler)
# Examples (replace <...>):
# DATABASE_URL=postgresql://postgres:<password>@<pooler-host>:6543/postgres?pgbouncer=true&schema=public
# DIRECT_URL=postgresql://postgres:<password>@<direct-host>:5432/postgres?schema=public
DATABASE_URL=
DIRECT_URL=

# Auth (JWT)
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m

# Devices
# Minutes without telemetry before considering a device OFFLINE
DEVICE_OFFLINE_MINUTES=1

# MQTT (optional)
# If MQTT_URL is empty, MQTT ingestion is disabled.
MQTT_URL=
MQTT_USERNAME=
MQTT_PASSWORD=

# Topic pattern for telemetry. Default expects messages at: iot/<uid>/telemetry
MQTT_TELEMETRY_TOPIC=iot/+/telemetry

# Device Simulator (publishes MQTT telemetry)
# Comma-separated UIDs (must match Device.uid in DB)
SIM_DEVICE_UIDS=dev-001,dev-002,dev-003

# Publish interval
SIM_INTERVAL_MS=5000

# Probability [0..1] that a message is abnormal (produces WARNING)
SIM_ANOMALY_RATE=0.05
